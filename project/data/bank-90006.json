[{"id":"90006-01-1","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[2],"stem":"對於核計勞工所得有無低於基本（最低）工資，下列何者錯誤？","opts":["僅計入在正常工時內之報酬","應計入加班費","不計入休假日出勤加給之工資","不計入競賽獎金"],"img":false},{"id":"90006-01-2","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[3],"stem":"下列何者之工資日數得列入計算平均工資？","opts":["請事假期間","職災醫療期間","發生計算事由之當日前 6 個月","放無薪假期間"],"img":false},{"id":"90006-01-3","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[4],"stem":"有關「例假」之敘述，下列何者錯誤？","opts":["每 7 日應有例假 1 日","工資照給","天災出勤時，工資加倍及補休","須給假，不必給工資"],"img":false},{"id":"90006-01-4","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[4],"stem":"勞動基準法第 84 條之 1 規定之工作者，因工作性質特殊，就其工作時間之敘述，下列何者正確？","opts":["完全不受限制","無例假與休假","不另給予延時工資","得由勞雇雙方另行約定"],"img":false},{"id":"90006-01-5","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[3],"stem":"依勞動基準法規定，雇主應置備勞工工資清冊並應保存幾年？","opts":["1 年","2 年","5 年","10 年"],"img":false},{"id":"90006-01-6","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[1],"stem":"事業單位僱用勞工多少人以上者，應依勞動基準法規定訂立工作規則？","opts":["30 人","50 人","100 人","200 人"],"img":false},{"id":"90006-01-7","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[3],"stem":"依勞動基準法規定，雇主延長勞工之工作時間連同正常工作時間，每日不 得超過多少小時？","opts":["10 小時","11 小時","12 小時","15 小時"],"img":false},{"id":"90006-01-8","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[4],"stem":"依勞動基準法規定，下列何者屬不定期契約？","opts":["臨時性或短期性的工作","季節性的工作","特定性的工作","有繼續性的工作"],"img":false},{"id":"90006-01-9","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[1],"stem":"依職業安全衛生法規定，事業單位勞動場所發生死亡職業災害時，雇主應於多少小時內通報勞動檢查機構？","opts":["8 小時","12 小時","24 小時","48 小時"],"img":false},{"id":"90006-01-10","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[4],"stem":"有關事業單位之勞資會議主席，下列何者正確？","opts":["由企業工會推派之","由產業工會推派之","由勞資雙方協議推派之","由勞資雙方輪流擔任之"],"img":false},{"id":"90006-01-11","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[4],"stem":"職業安全衛生法所稱有母性健康危害之虞之工作，不包括下列何種工作型態？","opts":["長時間站立姿勢作業","人力提舉、搬運及推拉重物","輪班及工作負荷","駕駛運輸車輛"],"img":false},{"id":"90006-01-12","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[3],"stem":"依職業安全衛生法施行細則規定，下列何者非屬特別危害健康之作業？","opts":["噪音作業","游離輻射作業","會計作業","粉塵作業"],"img":false},{"id":"90006-01-13","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[3],"stem":"從事於易踏穿材料構築之屋頂修繕作業時，應有何種作業主管在場執行主管業務？","opts":["施工架組配","擋土支撐組配","屋頂","模板支撐"],"img":false},{"id":"90006-01-14","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[4],"stem":"有關「工讀生」之敘述，下列何者正確？","opts":["工資不得低於基本工資之 80 ％","屬短期工作者，加班只能補休","每日正常工作時間得超過 8 小時","國定假日出勤，工資加倍發給"],"img":false},{"id":"90006-01-15","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[3],"stem":"勞工工作時手部嚴重受傷，住院醫療期間公司應按下列何者給予職業災害補償？","opts":["前 6 個月平均工資","前 1 年平均工資","原領工資","基本工資"],"img":false},{"id":"90006-01-16","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[2],"stem":"勞工在何種情況下，雇主得不經預告終止勞動契約？","opts":["確定被法院判刑 6 個月以內並諭知緩刑超過 1 年以上者","不服指揮對雇主暴力相向者","經常遲到早退者","非連續曠工但 1 個月內累計 3 日者"],"img":false},{"id":"90006-01-17","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[3],"stem":"對於吹哨者保護規定，下列何者錯誤？","opts":["事業單位不得對勞工申訴人終止勞動契約","勞動檢查機構受理勞工申訴必須保密","為實施勞動檢查，必要時得告知事業單位有關勞工申訴人身分","事業單位不得有不利勞工申訴人之處分"],"img":false},{"id":"90006-01-18","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[4],"stem":"職業安全衛生法所稱有母性健康危害之虞之工作，係指對於具生育能力之女性勞工從事工作，可能會導致的一些影響。下列何者除外？","opts":["胚胎發育","妊娠期間之母體健康","哺乳期間之嬰兒健康","經期紊亂"],"img":false},{"id":"90006-01-19","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[3],"stem":"下列何者非屬職業安全衛生法規定之勞工法定義務？","opts":["定期接受健康檢查","參加安全衛生教育訓練","實施自動檢查","遵守安全衛生工作守則"],"img":false},{"id":"90006-01-20","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[2],"stem":"下列何者非屬應對在職勞工施行之健康檢查？","opts":["一般健康檢查","體格檢查","特殊健康檢查","特定對象及特定項目之檢查"],"img":false},{"id":"90006-01-21","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[4],"stem":"下列何者非為防範有害物食入之方法？","opts":["有害物與食物隔離","不在工作場所進食或飲水","常洗手、漱口","穿工作服"],"img":false},{"id":"90006-01-22","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[1],"stem":"原事業單位如有違反職業安全衛生法或有關安全衛生規定，致承攬人所僱勞工發生職業災害時，有關承攬管理責任，下列敘述何者正確？","opts":["原事業單位應與承攬人負連帶賠償責任","原事業單位不需負連帶補償責任","承攬廠商應自負職業災害之賠償責任","勞工投保單位即為職業災害之賠償單位"],"img":false},{"id":"90006-01-23","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[4],"stem":"依勞動基準法規定，主管機關或檢查機構於接獲勞工申訴事業單位違反本法及其他勞工法令規定後，應為必要之調查，並於幾日內將處理情形，以書面通知勞工？","opts":["14 日","20 日","30 日","60 日"],"img":false},{"id":"90006-01-24","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[3],"stem":"我國中央勞動業務主管機關為下列何者？","opts":["內政部","勞工保險局","勞動部","經濟部"],"img":false},{"id":"90006-01-25","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[4],"stem":"對於勞動部公告列入應實施型式驗證之機械、設備或器具，下列何種情形不得免驗證？","opts":["依其他法律規定實施驗證者","供國防軍事用途使用者","輸入僅供科技研發之專用機型","輸入僅供收藏使用之限量品"],"img":false},{"id":"90006-01-26","subj":"common","code":"90006","wi":"01","cat":"職業安全衛生","catShort":"職安","type":"single","ans":[4],"stem":"對於墜落危險之預防設施，下列敘述何者較為妥適？","opts":["在外牆施工架等高處作業應盡量使用繫腰式安全帶","安全帶應確實配掛在低於足下之堅固點","高度 2m 以上之邊緣開口部分處應圍起警示帶","高度 2m 以上之開口處應設護欄或安全網"],"img":false},{"id":"90006-01-27","subj":"common","code":"90006","wi":"01","ca